# PolySuite Environment Variables
# Copy to .env and fill in your values. See README for setup instructions.

# Required for alerts
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/YOUR_WEBHOOK_ID/YOUR_WEBHOOK_TOKEN
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_from_botfather
TELEGRAM_CHAT_ID=your_telegram_chat_id

# Optional: Discord bot for slash commands
DISCORD_BOT_TOKEN=your_discord_bot_token
DISCORD_APPLICATION_ID=your_discord_application_id

# Polymarket API (for wallet tracking, trades)
POLYMARKET_API_KEY=your_polymarket_api_key
POLYMARKET_API_SECRET=your_polymarket_api_secret
POLYMARKET_API_PASSPHRASE=your_polymarket_api_passphrase

# Optional: AI (Groq or OpenRouter)
GROQ_API_KEY=your_groq_api_key
OPENROUTER_API_KEY=your_openrouter_api_key

# Optional: Bankr
BANKR_API_KEY=your_bankr_api_key

# Optional: Additional webhooks
DISCORD_ALERTS_WEBHOOK_URL=
DISCORD_TRENDS_WEBHOOK_URL=
TELEGRAM_ALERTS_CHAT_ID=
TELEGRAM_TRENDS_CHAT_ID=
TELEGRAM_HEALTH_CHAT_ID=

# Dashboard — local use: leave auth OFF (no key needed in browser).
# Only set DASHBOARD_REQUIRE_AUTH=true + DASHBOARD_API_KEY when exposing the dash remotely.
DASHBOARD_API_KEY=
DASHBOARD_CORS_ORIGINS=http://127.0.0.1:5000
FLASK_SECRET_KEY=
DASHBOARD_REQUIRE_AUTH=false

# Copy trading credential storage (required for live copy; optional for dry-run)
# Generate: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
CREDENTIAL_ENCRYPTION_KEY=
COPY_DEFAULT_USER_ID=

# Copy safety (set in config.json): copy_max_trades_per_minute, copy_reduce_multiplier_after_trades,
# copy_reduced_multiplier, copy_reduction_window_minutes, copy_freeze_after_trades, copy_freeze_duration_minutes
